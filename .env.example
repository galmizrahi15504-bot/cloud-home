# ============================================================
# ☁️ CLOUD HOME — Environment Variables
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# Generate secrets easily:
#   openssl rand -hex 32
# ============================================================

# -- Your Domain & Identity --
DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com
TIMEZONE=UTC

# -- PostgreSQL (shared) --
POSTGRES_USER=cloudadmin
POSTGRES_PASSWORD=

# -- Immich (separate database) --
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=

# -- Authelia (SSO) — generate each with: openssl rand -hex 32 --
AUTHELIA_JWT_SECRET=
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=

# -- Nextcloud --
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=

# -- Vaultwarden — generate with: openssl rand -base64 48 --
VAULTWARDEN_ADMIN_TOKEN=
VAULTWARDEN_SIGNUPS=true

# -- Open WebUI --
OPENWEBUI_SECRET=

# -- n8n — generate with: openssl rand -hex 32 --
N8N_ENCRYPTION_KEY=

# -- SearXNG --
SEARXNG_SECRET=

# -- External AI APIs (optional) --
OPENAI_API_KEY=
OPENAI_API_BASE=

# -- Media path on server --
MEDIA_PATH=./media

# -- Backup (Backblaze B2) --
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
B2_BUCKET=
RESTIC_PASSWORD=

# -- Security Layer (optional but recommended) --
CLOUDFLARE_TUNNEL_TOKEN=
CROWDSEC_BOUNCER_KEY=
TAILSCALE_AUTH_KEY=
