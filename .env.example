# ============================================================
# ☁️ CLOUD HOME — Your Settings
# ============================================================
# Step 1: cp .env.example .env
# Step 2: bash scripts/generate-secrets.sh
# Step 3: Edit the 3 lines marked "← CHANGE THIS"
# ============================================================

# ← CHANGE THIS: your domain (bought on Cloudflare)
DOMAIN=yourdomain.com

# ← CHANGE THIS: your email (for SSL certificates)
ACME_EMAIL=you@yourdomain.com

# ← CHANGE THIS: your timezone
# Find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC

# -- Database --
POSTGRES_USER=cloudadmin
POSTGRES_PASSWORD=

# -- Nextcloud (your files & photos) --
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=

# -- Vaultwarden (your passwords) --
# After creating your account, change VAULTWARDEN_SIGNUPS to false and restart
VAULTWARDEN_ADMIN_TOKEN=
VAULTWARDEN_SIGNUPS=true

# -- Open WebUI (AI chat) --
OPENWEBUI_SECRET=

# -- Claude AI (optional but recommended) --
# Get your key at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# -- OpenAI / GPT (optional) --
OPENAI_API_KEY=

# -- Media path (where your movies/shows/music live on the server) --
# Only needed if using Jellyfin
MEDIA_PATH=./media

# -- Backup (Backblaze B2) --
# Sign up free at: backblaze.com → App Keys
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
B2_BUCKET=cloud-home-backup
RESTIC_PASSWORD=
